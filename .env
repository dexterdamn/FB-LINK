# =============================================================================
# Key pieces for Facebook Pages integration
# =============================================================================
# 1) Access tokens — User logs in (FB.login); app gets a user access token, then
#    GET /me/accounts returns Page objects each with a Page access token. All
#    Page edge calls in this app use that Page token (not the user token).
# 2) Graph API — This SPA calls GET/POST/DELETE on graph.facebook.com (see
#    src/services/facebookService.js). Production apps should proxy tokens via
#    a backend instead of storing Page tokens in the browser.
# 3) Webhooks — Real-time Page updates are delivered to YOUR server (HTTPS).
#    This Vite frontend does not receive webhooks. In Meta App Dashboard subscribe
#    your backend URL to Page fields (e.g. feed) and implement GET (hub verify)
#    + POST (signed payloads). Backend env example: META_WEBHOOK_VERIFY_TOKEN
# =============================================================================

# Facebook App (Meta Developer → App → Settings → Basic)
VITE_FACEBOOK_APP_ID=2216704592425960

# =============================================================================
# Redirect-based OAuth (backend) — REQUIRED for facebook.com redirect login
# =============================================================================
# Server-side app secret (do NOT expose as VITE_*). Put your Meta App Secret here:
FACEBOOK_APP_SECRET=3c9f5e22a82ee6aa14e6eed886d5d305
# Frontend URL where the user should land after Facebook redirects back to the backend callback.
# Vite dev server is HTTP on localhost, so keep this HTTP to avoid ERR_SSL_PROTOCOL_ERROR.
FRONTEND_ORIGIN=http://localhost:8000




# Share dialog will refuse domains not allowlisted in Meta App settings.
# For local dev, keep this HTTP (localhost is allowed on HTTP) and add `localhost` to App Domains.
VITE_FACEBOOK_SHARE_FALLBACK_URL=http://localhost:8000/
# FRONTEND_ORIGIN=https://abcd-1234.ngrok-free.app
# Optional: override app id/version/scopes on the backend (defaults to VITE_* values)
# FACEBOOK_APP_ID=1456564855400610
# FACEBOOK_API_VERSION=v18.0
FACEBOOK_LOGIN_SCOPES=public_profile,pages_show_list,pages_read_engagement,pages_manage_posts
# Lock the web app target page (recommended): use the numeric Page ID.
FACEBOOK_LGU_PAGE_ID=1118520498005648
FACEBOOK_LGU_PAGE_NAME=lgu-page
# Graph API version (e.g. https://graph.facebook.com/v18.0/...)
VITE_FACEBOOK_API_VERSION=v18.0


FACEBOOK_SERVER_PAGE_ID=1118520498005648
FACEBOOK_SERVER_PAGE_NAME=lgu-page
FACEBOOK_SERVER_PAGE_ACCESS_TOKEN=EAAfgFMHNsZBgBRYgahU8mZB9ID43cZCEFxdmWO3jRihEMZCsFOJd06ZB7TGa94wU8sfRZCMLUCP1NiDZBgOzMSkOolWPI6G9W8lpPmZBKz2tbTXtssVdAlQavHFz2hCRiORmTQxLWZA91V9v9PyAHyDEISMxCTRF5cUuyHrYeNse4tnZAOtsvzpZAvhcn5d9bdXI8Qcm9vjY4I6QRm9sFHMrvKwK66ll3nsfV9sJZAiVUSoybOsZD
# Add your site URL under Facebook Login → Settings → Valid OAuth Redirect URIs
# Example dev (see vite.config.js port): http://localhost:8000/

# If login shows "Invalid Scopes: email, pages_show_list, …" the names are valid but
# Meta has NOT attached them to YOUR app yet. Fix in App Dashboard (not in code):
# - Add a Pages / "manage Page content" use case if missing.
# - App → Permissions and features (or Use case → permissions): enable each scope
#   you request (email, pages_show_list, pages_read_engagement, pages_manage_posts).
# - Ensure Facebook Login product is added; redirect URI includes this origin.
# Docs: https://developers.facebook.com/docs/development/create-an-app/pages-use-case
#
# Optional: override ALL login scopes (comma-separated). Try: public_profile
# VITE_FACEBOOK_LOGIN_SCOPES=public_profile
#
# Login scopes (base). Optional: comma-separated extra Graph permissions, e.g.
# pages_manage_engagement,pages_read_user_content
# VITE_FACEBOOK_EXTRA_SCOPES=

# Base scopes: public_profile, email, pages_show_list, pages_read_engagement, pages_manage_posts
# Other permissions (request only what your app review needs):
# - pages_manage_engagement — moderate comments, delete posts
# - pages_read_user_content — read UGC on the Page
# - pages_manage_metadata — Page settings
# - pages_manage_ads / pages_manage_cta / pages_messaging / business_management — as needed

# Page GET: GET /{page-id}?fields=id,name,about,fan_count
# Page POST: POST /{page-id}/feed — message, link, picture, published
# Page photos (local file): POST /{page-id}/photos (multipart)

# Optional
# VITE_API_BASE_URL=https://api.example.com
# VITE_APP_NAME=Social Echo
# VITE_APP_ENVIRONMENT=development
